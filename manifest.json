{
  "manifest_version": 3,
  "name": "CB_測試用擴充功能",
  "version": "1.0",
  "description": "CB_測試用擴充功能",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "static/icons/icon16.png",
      "48": "static/icons/icon48.png",
      "128": "static/icons/icon128.png"
    }
  },
  "icons": {
    "16": "static/icons/icon16.png",
    "48": "static/icons/icon48.png",
    "128": "static/icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cloud.nueip.com/*",
        "https://www.youtube.com/*",
        "https://rent.591.com.tw/*"
      ],
      "js": [
        "static/jquery-3.5.1/jquery.min.js",
        "src/inject-config/sites.js",
        "src/content.js"
      ]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "notifications",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://cloud.nueip.com/*",
    "https://www.youtube.com/*",
    "https://rent.591.com.tw/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/inject/**/*", "src/config/*"],
      "matches": [
        "https://cloud.nueip.com/*",
        "https://www.youtube.com/*",
        "https://rent.591.com.tw/*"
      ]
    }
  ]
}