{
  "manifest_version": 3,
  "name": "Worklohas 擴充功能",
  "version": "1.0",
  "description": "快速打卡 | 複製內文 | 改變網站樣式 | 測試站帳密儲存與填入",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "static/img/icons/icon16.png",
      "48": "static/img/icons/icon48.png",
      "128": "static/img/icons/icon128.png"
    }
  },
  "icons": {
    "16": "static/img/icons/icon16.png",
    "48": "static/img/icons/icon48.png",
    "128": "static/img/icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cloud.nueip.com/*",
        "https://rent.591.com.tw/*",
        "https://projects.worklohas.com/*",
        "https://*.worklohas.com/*",
        "https://*.worklohas.dev/*"
      ],
      "js": [
        "static/plugins/jquery-3.6.4/jquery.min.js",
        "src/inject/sites.js",
        "src/content.js"
      ]
    }
  ],
  "host_permissions": [
    "https://cloud.nueip.com/*",
    "https://rent.591.com.tw/*",
    "https://*.worklohas.com/*",
    "https://*.worklohas.dev/*",
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/inject/**/*"
      ],
      "matches": [
        "https://cloud.nueip.com/*",
        "https://rent.591.com.tw/*",
        "https://projects.worklohas.com/*",
        "https://*.worklohas.com/*",
        "https://*.worklohas.dev/*"
      ]
    }
  ],
  "permissions": [
    "storage",
    "clipboardWrite",
    "identity"
  ],
  "oauth2": {
    "client_id": "804323187732-i12d3em757ot67fj9muc26micfi6e8ig.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/drive.file"
    ]
  }
}