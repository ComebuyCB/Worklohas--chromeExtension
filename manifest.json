{
  "manifest_version": 3,
  "name": "NUEIP 自動打卡",
  "version": "1.0",
  "description": "NUEIP 自動打卡擴充功能",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "static/icons/icon16.png",
      "48": "static/icons/icon48.png",
      "128": "static/icons/icon128.png"
    }
  },
  "icons": {
    "16": "static/icons/icon16.png",
    "48": "static/icons/icon48.png",
    "128": "static/icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cloud.nueip.com/attendance_record*"],
      "js": [
        "static/jquery-3.5.1/jquery.min.js",
        "content.js"
      ]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://cloud.nueip.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject/testExtension-inject.js", "inject/testExtension-inject.css"],
      "matches": ["https://cloud.nueip.com/*"]
    }
  ]
}