{
  "manifest_version": 3,
  "version": "1.630.1",
  "description": "快速打卡 | 複製內文 | 改變網站樣式 | 測試站帳密儲存與填入",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "static/img/icons/icon-16.png",
      "48": "static/img/icons/icon-48.png",
      "128": "static/img/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "static/img/icons/icon-b16.png",
    "48": "static/img/icons/icon-b48.png",
    "128": "static/img/icons/icon-b128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cloud.nueip.com/*",
        "https://rent.591.com.tw/*",
        "https://projects.worklohas.com/*",
        "https://*.worklohas.com/*",
        "https://*.worklohas.dev/*"
      ],
      "js": [
        "static/plugins/jquery-3.6.4/jquery.min.js",
        "src/inject/sites.js",
        "src/content.js"
      ]
    }
  ],
  "host_permissions": [
    "https://cloud.nueip.com/*",
    "https://rent.591.com.tw/*",
    "https://*.worklohas.com/*",
    "https://*.worklohas.dev/*",
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/inject/**/*"
      ],
      "matches": [
        "https://cloud.nueip.com/*",
        "https://rent.591.com.tw/*",
        "https://projects.worklohas.com/*",
        "https://*.worklohas.com/*",
        "https://*.worklohas.dev/*"
      ]
    }
  ],
  "permissions": [
    "storage",
    "clipboardWrite",
    "identity"
  ]
}
